OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_VECTOR_STORE_ID=
AMH_REFERENCE_MODE=file-search

# Use a mounted persistent server directory in production.
ANSWER_STORE_PATH=/data/oral-exam-answers.json

# Applies only to new generation/Refresh requests. Cached answers do not use this allowance.
RATE_LIMIT_PER_HOUR=20
